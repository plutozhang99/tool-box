# claude-nexus configuration

# REQUIRED: Directory for nexus data (SQLite DB, identity keys, notifications)
# Must be set per project to ensure data isolation.
NEXUS_DATA_DIR=~/.claude-nexus/my-project

# Heartbeat interval in milliseconds (default: 30000)
# NEXUS_HEARTBEAT_INTERVAL=30000

# Remote relay server URL
# NEXUS_RELAY_URL=wss://your-relay.example.com

# Optional passphrase for encrypting the identity keypair at rest
# NEXUS_IDENTITY_PASSPHRASE=

# Relay server port (for self-hosted relay)
# RELAY_PORT=3001
