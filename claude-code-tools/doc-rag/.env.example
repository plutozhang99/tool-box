# === LLM API Keys (at least one required) ===
ANTHROPIC_API_KEY=sk-ant-xxx
OPENROUTER_API_KEY=sk-or-xxx

# === Project config (required for docker-compose / serve.sh) ===
DOC_RAG_DOCS_DIR=/path/to/your/docs
DOC_RAG_PROJECT=your_project_name

# === Optional ===
# DOC_RAG_LLM_PROVIDER=anthropic     # or "openrouter"
# DOC_RAG_LLM_MODEL=claude-sonnet-4-20250514
# DOC_RAG_PORT=8100
